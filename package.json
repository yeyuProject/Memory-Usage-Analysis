{
  "name": "memory-usage-analysis",
  "version": "1.0.0",
  "description": "Windows程序内存占用分析工具",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win"
  },
  "keywords": ["memory", "analysis", "windows", "electron"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.memory-analysis.app",
    "productName": "Memory Usage Analysis",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
