{
  "name": "memory-usage-analysis",
  "version": "1.0.0",
  "description": "Windows程序内存占用分析工具",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win",
    "test": "node test/run-all.cjs",
    "test:spike": "node test-spike.cjs",
    "test:leak": "node test-leak.cjs",
    "test:search": "node test-search.cjs",
    "test:config": "node test-config.cjs",
    "test:snapshot": "node test-snapshot.cjs",
    "test:recording": "node test-recording.cjs",
    "test:long-session": "node test-long-session.cjs",
    "test:smart-search": "node test-smart-search.cjs",
    "test:copytop50": "node test-copytop50.cjs",
    "test:stats-bar": "node test-stats-bar.cjs",
    "test:context-menu": "node test-context-menu.cjs",
    "test:refactor": "node test-refactor.cjs",
    "bench:powershell": "node bench-powershell.cjs",
    "bench:renderer": "node bench-renderer.cjs"
  },
  "keywords": ["memory", "analysis", "windows", "electron"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.memory-analysis.app",
    "productName": "Memory Usage Analysis",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
